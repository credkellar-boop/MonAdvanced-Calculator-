import numpy as np
from typing import Callable

class OptimizationAlgorithms:
    @staticmethod
    def gradient_descent(
        gradient_func: Callable[[np.ndarray], np.ndarray],
        start_point: np.ndarray,
        learning_rate: float = 0.01,
        tolerance: float = 1e-6,
        max_iterations: int = 10000
    ) -> np.ndarray:
        """
        Finds the local minimum of a multi-dimensional function using gradient descent.
        Useful for optimizing flight paths or minimizing fuel consumption.
        """
        current_point = np.array(start_point, dtype=float)
        
        for _ in range(max_iterations):
            grad = np.array(gradient_func(current_point))
            step = learning_rate * grad
            
            if np.linalg.norm(step) < tolerance:
                break
                
            current_point -= step
            
        return current_point

